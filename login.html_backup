<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<title>Logg inn — dialr</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0a0f;--bg2:#111118;--bg3:#18181f;--border:#22222e;--border2:#2e2e3e;
  --text:#f0f0f5;--muted:#6b6b80;--muted2:#4a4a5a;--accent:#7c6af7;--accent2:#9b8cff;
  --accent-bg:rgba(124,106,247,0.08);--accent-border:rgba(124,106,247,0.25);
  --green:#34d399;--red:#f87171;
}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;-webkit-font-smoothing:antialiased;}
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.4;}
.wrap{width:100%;max-width:400px;padding:24px;position:relative;z-index:1;}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:40px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
.logo{font-family:'DM Mono',monospace;font-size:28px;font-weight:500;color:var(--text);text-align:center;margin-bottom:8px;}
.logo span{color:var(--accent)}
.tagline{font-size:14px;color:var(--muted);text-align:center;margin-bottom:32px;}
.tabs{display:flex;gap:2px;background:var(--bg3);border-radius:10px;padding:4px;margin-bottom:28px;}
.tab{flex:1;padding:8px;border-radius:7px;font-size:13px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--muted);transition:all 0.15s;font-family:'Inter',sans-serif;}
.tab.active{background:var(--bg2);color:var(--text);}
.field{margin-bottom:16px;}
.field label{display:block;font-size:12px;color:var(--muted);font-family:'DM Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;}
.field input{width:100%;background:var(--bg3);border:1.5px solid var(--border2);border-radius:10px;padding:14px 16px;font-family:'Inter',sans-serif;font-size:15px;color:var(--text);outline:none;transition:border-color 0.15s;}
.field input:focus{border-color:var(--accent);}
.field input::placeholder{color:var(--muted2)}
.btn{width:100%;height:50px;background:var(--accent);border:none;border-radius:10px;color:#fff;font-size:15px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:all 0.15s;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn:hover{background:var(--accent2);transform:translateY(-1px)}
.btn:disabled{opacity:0.4;cursor:not-allowed;transform:none}
.msg{margin-top:16px;padding:12px 16px;border-radius:8px;font-size:13px;display:none;}
.msg.error{background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2);color:var(--red);}
.msg.success{background:rgba(52,211,153,0.08);border:1px solid rgba(52,211,153,0.2);color:var(--green);}
.spin{display:inline-block;width:15px;height:15px;border:2px solid rgba(255,255,255,0.2);border-top-color:#fff;border-radius:50%;animation:spin 0.55s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div class="logo">dial<span>r</span></div>
    <div class="tagline">Finn direktenummeret til daglig leder</div>

    <div class="tabs">
      <button class="tab active" id="loginTab" onclick="switchAuthTab('login')">Logg inn</button>
      <button class="tab" id="registerTab" onclick="switchAuthTab('register')">Registrer</button>
    </div>

    <div id="loginForm">
      <div class="field">
        <label>E-post</label>
        <input type="email" id="loginEmail" placeholder="din@epost.no">
      </div>
      <div class="field">
        <label>Passord</label>
        <input type="password" id="loginPassword" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
      </div>
      <button class="btn" id="loginBtn" onclick="doLogin()">
        <span class="spin" id="loginSpin" style="display:none"></span>
        <span id="loginBtnTxt">Logg inn</span>
      </button>
    </div>

    <div id="registerForm" style="display:none">
      <div class="field">
        <label>E-post</label>
        <input type="email" id="regEmail" placeholder="din@epost.no">
      </div>
      <div class="field">
        <label>Passord</label>
        <input type="password" id="regPassword" placeholder="Minst 6 tegn" onkeydown="if(event.key==='Enter')doRegister()">
      </div>
      <button class="btn" id="registerBtn" onclick="doRegister()">
        <span class="spin" id="registerSpin" style="display:none"></span>
        <span id="registerBtnTxt">Opprett konto</span>
      </button>
    </div>

    <div class="msg" id="authMsg"></div>
  </div>
</div>

<script>
const SUPABASE_URL = "https://lvhlslkiaazuytezajsw.supabase.co";
const SUPABASE_KEY = "sb_publishable_FsGNBrVWfEYf4O0a6A3dTw_DiW7YITe";
const { createClient } = supabase;
const sb = createClient(SUPABASE_URL, SUPABASE_KEY);

function switchAuthTab(t) {
  document.getElementById('loginTab').classList.toggle('active', t === 'login');
  document.getElementById('registerTab').classList.toggle('active', t === 'register');
  document.getElementById('loginForm').style.display = t === 'login' ? 'block' : 'none';
  document.getElementById('registerForm').style.display = t === 'register' ? 'block' : 'none';
  hideMsg();
}

async function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const password = document.getElementById('loginPassword').value;
  if(!email || !password) { showMsg('Fyll inn e-post og passord.', 'error'); return; }
  
  setLoading('login', true);
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  
  if(error) {
    showMsg('Feil e-post eller passord.', 'error');
    setLoading('login', false);
    return;
  }

  // Check if approved
  const { data: profile } = await sb.from('profiles').select('approved').eq('email', email).single();
  
  if(!profile || !profile.approved) {
    await sb.auth.signOut();
    showMsg('Kontoen din er ikke godkjent ennå. Ta kontakt med Isak.', 'error');
    setLoading('login', false);
    return;
  }

  window.location.href = 'index.html';
}

async function doRegister() {
  const email = document.getElementById('regEmail').value.trim();
  const password = document.getElementById('regPassword').value;
  if(!email || !password) { showMsg('Fyll inn e-post og passord.', 'error'); return; }
  if(password.length < 6) { showMsg('Passordet må være minst 6 tegn.', 'error'); return; }
  
  setLoading('register', true);
  const { error } = await sb.auth.signUp({ email, password });
  
  if(error) {
    showMsg(error.message, 'error');
    setLoading('register', false);
    return;
  }

  // Add to profiles table as not approved
  await sb.from('profiles').insert({ email, approved: false, access_level: 'full' });
  
  showMsg('Konto opprettet! Isak må godkjenne tilgangen din før du kan logge inn.', 'success');
  setLoading('register', false);
}

function setLoading(type, loading) {
  document.getElementById(type+'Btn').disabled = loading;
  document.getElementById(type+'Spin').style.display = loading ? 'inline-block' : 'none';
  document.getElementById(type+'BtnTxt').textContent = loading ? '' : (type === 'login' ? 'Logg inn' : 'Opprett konto');
}

function showMsg(msg, type) {
  const el = document.getElementById('authMsg');
  el.textContent = msg;
  el.className = 'msg ' + type;
  el.style.display = 'block';
}

function hideMsgEl() { document.getElementById('authMsg').style.display = 'none'; }
function hideMsg() { hideMsgEl(); }

// Check if already logged in
sb.auth.getSession().then(async ({ data: { session } }) => {
  if(session) {
    const { data: profile } = await sb.from('profiles').select('approved').eq('email', session.user.email).single();
    if(profile && profile.approved) window.location.href = 'index.html';
  }
});
</script>
</body>
</html>
